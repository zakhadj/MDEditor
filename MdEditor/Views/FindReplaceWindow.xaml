<Window x:Class="MdEditor.Views.FindReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rechercher"
        Icon="/Resources/MD-Editor-Icon.png"
        Width="420" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundPrimaryBrush}"
        FontFamily="{StaticResource SansFontFamily}">
    <StackPanel Margin="18">
        <TextBlock Text="Rechercher" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2" />
        <TextBox x:Name="SearchTextBox" Style="{StaticResource FieldTextBoxStyle}" Margin="0,0,0,10"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" KeyDown="SearchTextBox_KeyDown" />

        <StackPanel x:Name="ReplacePanel">
            <TextBlock Text="Remplacer par" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2" />
            <TextBox x:Name="ReplaceTextBox" Style="{StaticResource FieldTextBoxStyle}" Margin="0,0,0,10"
                     Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}" KeyDown="ReplaceTextBox_KeyDown" />
        </StackPanel>

        <CheckBox Content="Respecter la casse" IsChecked="{Binding MatchCase}" Margin="0,0,0,12"
                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" />

        <WrapPanel x:Name="FindButtonsPanel">
            <Button Content="Rechercher (onglet actuel)" Style="{StaticResource FlatButtonStyle}"
                    Command="{Binding FindInCurrentTabCommand}" Margin="0,0,8,8" />
            <Button Content="Rechercher (tous les onglets)" Style="{StaticResource FlatButtonStyle}"
                    Command="{Binding FindInAllTabsCommand}" Margin="0,0,8,8" />
        </WrapPanel>

        <WrapPanel x:Name="ReplaceButtonsPanel" Visibility="Collapsed">
            <Button Content="Remplacer (onglet actuel)" Style="{StaticResource FlatButtonStyle}"
                    Command="{Binding ReplaceInCurrentTabCommand}" Margin="0,0,8,8" />
            <Button Content="Remplacer (tous les onglets ouverts)" Style="{StaticResource FlatButtonStyle}"
                    Command="{Binding ReplaceInAllTabsCommand}" Margin="0,0,8,8" />
        </WrapPanel>

        <TextBlock Text="{Binding StatusMessage}" Margin="0,4,0,0" FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
    </StackPanel>
</Window>
