<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="#1F1F1F" />
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="#2B2B2B" />
    <SolidColorBrush x:Key="BackgroundTertiaryBrush" Color="#333333" />
    <SolidColorBrush x:Key="BackgroundInfoBrush" Color="#16324A" />
    <SolidColorBrush x:Key="BackgroundDangerBrush" Color="#4A1F1F" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F3F2F1" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#C5C4C0" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#9A9890" />
    <SolidColorBrush x:Key="TextInfoBrush" Color="#7FB8EE" />
    <SolidColorBrush x:Key="TextDangerBrush" Color="#F28B82" />

    <SolidColorBrush x:Key="BorderTertiaryBrush" Color="#1FFFFFFF" />
    <SolidColorBrush x:Key="BorderSecondaryBrush" Color="#3DFFFFFF" />
    <SolidColorBrush x:Key="BorderPrimaryBrush" Color="#52FFFFFF" />
    <SolidColorBrush x:Key="BorderInfoBrush" Color="#3A6A98" />

    <SolidColorBrush x:Key="OuterBackdropBrush" Color="#141414" />

    <!-- Markdown preview palette (passed to WebView2 as CSS, kept in sync with the brushes above) -->
    <Color x:Key="PreviewBackgroundColor">#1F1F1F</Color>
    <Color x:Key="PreviewTextColor">#F3F2F1</Color>
    <Color x:Key="PreviewMutedTextColor">#C5C4C0</Color>
    <Color x:Key="PreviewBorderColor">#1FFFFFFF</Color>
    <Color x:Key="PreviewCodeBackgroundColor">#2B2B2B</Color>
    <Color x:Key="PreviewLinkColor">#7FB8EE</Color>
    <Color x:Key="PreviewHighlightColor">#16324A</Color>
    <Color x:Key="PreviewHighlightBorderColor">#3A6A98</Color>

</ResourceDictionary>
