<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="#F1EFE8" />
    <SolidColorBrush x:Key="BackgroundTertiaryBrush" Color="#E9E7DF" />
    <SolidColorBrush x:Key="BackgroundInfoBrush" Color="#E6F1FB" />
    <SolidColorBrush x:Key="BackgroundDangerBrush" Color="#FCEBEB" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#20201D" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5F5E5A" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#888780" />
    <SolidColorBrush x:Key="TextInfoBrush" Color="#0C447C" />
    <SolidColorBrush x:Key="TextDangerBrush" Color="#791F1F" />

    <SolidColorBrush x:Key="BorderTertiaryBrush" Color="#26000000" />
    <SolidColorBrush x:Key="BorderSecondaryBrush" Color="#4D000000" />
    <SolidColorBrush x:Key="BorderPrimaryBrush" Color="#66000000" />
    <SolidColorBrush x:Key="BorderInfoBrush" Color="#85B7EB" />

    <SolidColorBrush x:Key="OuterBackdropBrush" Color="#D9D7CD" />

    <!-- Markdown preview palette (passed to WebView2 as CSS, kept in sync with the brushes above) -->
    <Color x:Key="PreviewBackgroundColor">#FFFFFF</Color>
    <Color x:Key="PreviewTextColor">#20201D</Color>
    <Color x:Key="PreviewMutedTextColor">#5F5E5A</Color>
    <Color x:Key="PreviewBorderColor">#26000000</Color>
    <Color x:Key="PreviewCodeBackgroundColor">#F1EFE8</Color>
    <Color x:Key="PreviewLinkColor">#0C447C</Color>
    <Color x:Key="PreviewHighlightColor">#E6F1FB</Color>
    <Color x:Key="PreviewHighlightBorderColor">#85B7EB</Color>

</ResourceDictionary>
